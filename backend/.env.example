APP_ENV=production
APP_NAME=Qtiqo Share Backend
BASE_URL=https://imagelink.qtiqo.com
API_PORT=8080

DATABASE_URL=postgresql+psycopg://imagelink:change_me@db:5432/imagelink
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRE_MINUTES=43200

STORAGE_MODE=local
LOCAL_STORAGE_DIR=/data/uploads
PUBLIC_STORAGE_BASE_URL=https://imagelink.qtiqo.com/content

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=imagelink-files

DEFAULT_STORAGE_LIMIT_BYTES=104857600
DEFAULT_UPLOAD_LIMIT_BYTES=10485760
DOWNLOADS_ENABLED_BY_DEFAULT=true
PUBLIC_PAGES_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
CAPTCHA_ENABLED=false
